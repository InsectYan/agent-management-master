# 服务端口（与 config 默认 3001 一致）
PORT=3001

# 插件扫描目录（相对项目根目录）
PLUGIN_DIR=plugins

# Pi 工作区根目录
WORKSPACES_ROOT=workspaces

# ---------- LLM 平台默认（Priority 3：本地 Ollama）----------
LLM_PROVIDER=ollama
LLM_DEFAULT_PROFILE=ollama-qwen
OPENAI_API_KEY=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.6:latest

# 可选云端密钥（配置后对应 profile 的 available=true）
# ZHIPU_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=sk-...

# CORS（供独立前端联调）
CORS_ORIGIN=http://localhost:5173

# ---------- 本地数据库（SQLite，默认 data/agent.sqlite）----------
# SQLITE_PATH=./data/agent.sqlite
# 预留：未来可切换 PostgreSQL
# DATABASE_URL=postgres://user:pass@localhost:5432/agent_mgmt
