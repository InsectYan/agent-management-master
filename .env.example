# 服务端口
# AMS 注册表约定 Agent 平台为 4001（testgen AGENT_PLATFORM_URL 默认指向此端口）
# 若保持 3001，须同步改 testgen-sub 的 AGENT_PLATFORM_URL=http://127.0.0.1:3001
PORT=4001

# 插件扫描目录（相对项目根目录）
PLUGIN_DIR=plugins

# Pi 工作区根目录
WORKSPACES_ROOT=workspaces

# ---------- LLM 平台默认（Priority 3：本地 Ollama）----------
LLM_PROVIDER=ollama
LLM_DEFAULT_PROFILE=ollama-qwen
OPENAI_API_KEY=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.6:latest

# 可选云端密钥（配置后对应 profile 的 available=true）
# ZHIPU_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=sk-...

# CORS（本地个人平台默认全开放；不设或设为 * 即可。多来源用逗号分隔）
# CORS_ORIGIN=*

# 文件记忆目录（相对项目根）
# MEMORY_FILES_DIR=memory_files

# ---------- 数据库 ----------
# 本地 SQLite（默认，无 DATABASE_URL 时启用）
SQLITE_PATH=./data/agent.sqlite

# PostgreSQL + pgvector（agentm local:full 或自建 PG）
# 宿主机端口 5500，独立于各子应用 543x 段，避免冲突
POSTGRES_PORT=5500
# DATABASE_URL=postgresql://agent:agent_secret@localhost:5500/agent_mgmt

# 向量记忆后端：pgvector | keyword（SQLite 回退）
# MEMORY_VECTOR_BACKEND=pgvector
# OLLAMA_EMBED_MODEL=nomic-embed-text

# 睡梦记忆 worker（需 PostgreSQL）
# MEMORY_DREAM_WORKER=1
# MEMORY_DREAM_IDLE_MIN=5
# MEMORY_DREAM_POLL_MS=15000

# Pi 引擎：默认 pi-coding-agent；PI_LIGHTWEIGHT=1 强制轻量模式
# PI_LIGHTWEIGHT=0

# ---------- testgen-sub 联调（Skill 回写 BFF）----------
# testgen BFF 默认 5202（见 admin-management-station 端口注册表）
TESTGEN_BFF_URL=http://127.0.0.1:5202
# 与 testgen-sub backend INTERNAL_API_TOKEN 保持一致
TESTGEN_INTERNAL_TOKEN=

# ---------- Docker（agentm local 时由 deploy/config/.env.local 覆盖部分项）----------
# HOST=0.0.0.0
# OLLAMA_BASE_URL=http://localhost:11434/v1
