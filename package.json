{
  "name": "agent-management-master",
  "version": "0.2.0",
  "private": true,
  "description": "Egg.js 主 Agent 多方案平台（Agent + BFF）",
  "egg": {
    "typescript": false
  },
  "scripts": {
    "dev": "egg-bin dev",
    "debug": "egg-bin debug",
    "start": "egg-scripts start --title=agent-management",
    "stop": "egg-scripts stop --title=agent-management",
    "test": "egg-bin test",
    "test:unit": "egg-bin test",
    "test:all": "egg-bin test && node scripts/selftest-basic.js && node scripts/selftest-memory.js",
    "selftest": "node scripts/selftest-basic.js",
    "selftest:memory": "node scripts/selftest-memory.js",
    "selftest:sse": "node scripts/selftest-sse.js",
    "selftest:all": "node scripts/selftest-basic.js && node scripts/selftest-memory.js && node scripts/selftest-sse.js",
    "docker:local": "node deploy/scripts/run.mjs local",
    "docker:local:full": "node deploy/scripts/run.mjs local:full",
    "docker:local:host-ollama": "node deploy/scripts/run.mjs local:host-ollama",
    "docker:local:dev": "node deploy/scripts/run.mjs local:dev",
    "docker:down": "node deploy/scripts/run.mjs local:down",
    "docker:reset": "node deploy/scripts/run.mjs local:reset",
    "docker:status": "node deploy/scripts/run.mjs local:status",
    "docker:logs": "node deploy/scripts/run.mjs local:logs",
    "docker:pull-model": "node deploy/scripts/run.mjs local:pull-model",
    "docker:smoke": "node deploy/scripts/run.mjs local:smoke"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.77.0",
    "@earendil-works/pi-ai": "^0.77.0",
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "dotenv": "^16.4.7",
    "egg": "^3.28.0",
    "egg-cors": "^3.0.1",
    "egg-scripts": "^2.17.0",
    "jsonrepair": "^3.12.0",
    "pg": "^8.13.1",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "egg-bin": "^6.13.0",
    "egg-mock": "^5.12.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
